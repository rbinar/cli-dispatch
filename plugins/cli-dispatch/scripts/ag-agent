#!/usr/bin/env bash
# ag-agent — call the Antigravity (agy / Gemini) worker like a subagent: ONE command,
# live progress, final answer. The agy-backend twin of ds-agent.
#
#   ag-agent "<task>"                    # agentic in the current dir; streams tool activity; prints the answer
#   ag-agent --cwd <dir> "<task>"        # work in <dir>
#   ag-agent --resume <conv-id> "<follow-up>"  # continue an existing agy conversation
#   echo "<task>" | ag-agent             # task via stdin
#
# A thin SYNCHRONOUS wrapper over ag-stream: blocks until the worker is done, shows tool
# activity live on stderr, prints ONLY the final answer on stdout.
#
# NO read-only mode: unlike DeepSeek (claude --tools hard-restricts to read-only), agy has
# no tool-level write-deny (--sandbox restricts the terminal, not file writes — tested). So
# --read-only is rejected. For a no-writes guarantee, isolate via a throwaway/worktree --cwd
# and review the diff.
set -euo pipefail

usage() { echo 'usage: ag-agent [--cwd <dir>] [--resume <conv-id>] [--model <m>] [--max-runtime <s>] [--idle-timeout <s>] [-q] "<task>"' >&2; }

QUIET=0
TASK=""
HAVE_TASK=0
FWD=()
need_val() { [ "$2" -ge 2 ] || { echo "ag-agent: $1 requires a value." >&2; exit 1; }; }
while [ "$#" -gt 0 ]; do
  case "$1" in
    --read-only)      FWD+=(--read-only); shift;;
    --cwd)            need_val --cwd "$#";    FWD+=(--cwd "$2"); shift 2;;
    --resume)         need_val --resume "$#"; FWD+=(--resume "$2"); shift 2;;
    --model)          need_val --model "$#";  FWD+=(--model "$2"); shift 2;;
    --max-runtime)    need_val --max-runtime "$#";  FWD+=(--max-runtime "$2"); shift 2;;
    --idle-timeout)   need_val --idle-timeout "$#"; FWD+=(--idle-timeout "$2"); shift 2;;
    -q|--quiet)       QUIET=1; shift;;
    -p|--prompt)      need_val "$1" "$#"; TASK="$2"; HAVE_TASK=1; shift 2;;
    -h|--help)        usage; exit 0;;
    -*)               FWD+=("$1"); shift;;
    *)                TASK="$1"; HAVE_TASK=1; shift;;
  esac
done

if [ "$HAVE_TASK" -eq 0 ]; then
  if [ ! -t 0 ]; then TASK="$(cat)"; else usage; exit 1; fi
fi
if [ -z "${TASK//[[:space:]]/}" ]; then echo "ag-agent: empty task — nothing to delegate." >&2; exit 1; fi

STREAM="$(command -v ag-stream 2>/dev/null || true)"
[ -z "$STREAM" ] && STREAM="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ag-stream"
[ -x "$STREAM" ] || { echo "ag-agent: ag-stream not found (run /cli-dispatch:ds-setup)." >&2; exit 1; }

if [ "$QUIET" -eq 0 ]; then
  echo "▶ ag-agent → Antigravity (agy / Gemini) worker" >&2
  export AG_PROGRESS_STDERR=1
fi

set +e
"$STREAM" "${FWD[@]}" -p "$TASK"
rc=$?
set -e
exit "$rc"
